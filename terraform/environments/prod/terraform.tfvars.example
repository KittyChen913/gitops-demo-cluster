# 複製為 terraform.tfvars（已由 Git 忽略）後再調整。

region              = "ap-south"
k8s_version         = "1.35"
mgmt_node_type      = "g6-standard-4"
mgmt_node_count     = 3
worker_node_type    = "g6-standard-4"
worker_node_count   = 3
write_kubeconfig_files = true

# linode_token = ""  # 建議使用：export LINODE_TOKEN="..."

# OpenVPN 是 opt-in；root password 與 SSH user/host keys 均由 Terraform 產生。
# openvpn_enabled        = true
# openvpn_server_label   = "openvpn-prod"
# openvpn_instance_type  = "g6-standard-1"
# openvpn_image          = "linode/ubuntu24.04"
# openvpn_stackscript_id = 401719
# openvpn_stackscript_data = {
#   user_name         = "vpnadmin"
#   disable_root      = "Yes"
#   soa_email_address = "platform@example.com"
#   add_ons           = "none"
# }
# openvpn_port             = 1194
# openvpn_protocol         = "udp"
# openvpn_enable_ipv6      = false
# openvpn_bootstrap_http_enabled = true # 只限首次 Marketplace certbot；健康後改為 false
# openvpn_tunnel_cidr      = "172.27.224.0/20"
# openvpn_server_tunnel_ip = "172.27.224.1"
# internal_domain          = "corp.example"
# internal_dns_server_ip   = "172.27.224.1"
# argocd_internal_fqdn     = "argocd.corp.example"
# argocd_endpoint_host     = "192.0.2.20"
# argocd_endpoint_port     = 443
# argocd_destination_cidr  = "192.0.2.20/32"
# trusted_admin_cidrs      = ["198.51.100.10/32"]
# upstream_dns_servers     = ["1.1.1.1", "1.0.0.1"]
# openvpn_as_route_index   = 99
# openvpn_public_ipv4      = null # 可填入預期 IP 作相等性核對；不會保留或重新附加 IP
