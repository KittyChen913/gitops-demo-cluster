# 前置條件：dev/ 的 terraform apply 已完成且 remote state 存於 S3。
#
# 步驟：
# 1. cp backend.tf.example backend.tf
# 2. 填入 bucket / region
# 3. terraform init
# 4. terraform apply

terraform {
  backend "s3" {
    bucket  = "your-aws-tf-state-bucket"
    key     = "gitops-demo-cluster/dev-k8s/terraform.tfstate"
    region  = "ap-southeast-1"
    encrypt = true

    # （選用）啟用 state locking
    # dynamodb_table = "terraform-locks"
  }
}
