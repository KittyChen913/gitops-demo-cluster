# Rename to backend.tf after configuring remote state.
#
# Recommended: one state file per environment (dev / prod isolation).
#
# Example (S3-compatible object storage):
#
# terraform {
#   backend "s3" {
#     bucket         = "your-terraform-state"
#     key            = "gitops-demo-cluster/dev/terraform.tfstate"
#     region         = "us-east-1"
#     encrypt        = true
#     dynamodb_table = "terraform-locks"
#   }
# }
