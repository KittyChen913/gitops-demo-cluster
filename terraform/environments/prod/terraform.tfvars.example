# Copy to terraform.tfvars (gitignored) and adjust.

region              = "ap-south"
k8s_version         = "1.32"
mgmt_node_type      = "g6-standard-4"
mgmt_node_count     = 3
worker_node_type    = "g6-standard-4"
worker_node_count   = 3
write_kubeconfig_files = true

# linode_token = ""  # prefer: export LINODE_TOKEN="..."
